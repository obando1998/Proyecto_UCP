        <?php while($row = $result_solicitudes->fetch_assoc()): ?>
        <tr>
            <td><?php echo $row['id']; ?></td>
            <td><?php echo $row['no_orden_trabajo']; ?></td>
            <td><?php echo $row['fecha_solicitud']; ?></td>
            <td><?php echo $row['proceso']; ?></td>
            <td><?php echo $row['area']; ?></td>
            <td><?php echo $row['cargo']; ?></td>
            <td><?php echo $row['nombre_solicitante']; ?></td>
            <td><?php echo $row['hallazgo']; ?></td>
            <td><?php echo $row['estado']; ?></td>
            <td>
                <button onclick="mostrarFormularioAsignar(<?php echo $row['id']; ?>)">Asignar</button>
                <div id="form-asignar-<?php echo $row['id']; ?>" class="asignar-form">
                    <form method="post" action="">
                        <input type="hidden" name="solicitud_id" value="<?php echo $row['id']; ?>">
                        <select name="tecnico_id" required>
						
						// Reiniciar el puntero del resultado
                            mysqli_data_seek($result_tecnicos, 0);
                            while($tecnico = $result_tecnicos->fetch_assoc()): ?>
                            <option value="<?php echo $tecnico['id']; ?>"><?php echo $tecnico['nombre']; ?></option>
						
						
                            <?php while($tecnico = $result_tecnicos->fetch_assoc()): ?>
                            <option value="<?php echo $tecnico['id']; ?>"><?php echo $tecnico['nombre']; ?></option>
                            <?php endwhile; ?>
                        </select>
                        <input type="submit" value="Asignar">
                    </form>
                </div>
            </td>
        </tr>
        <?php endwhile; ?>
