    <script>
        function mostrarFormularioAsignar(solicitudId) {
            var form = document.getElementById('form-asignar-' + solicitudId);
            if (form.style.display === 'none') {
                form.style.display = 'block';
            } else {
                form.style.display = 'none';
            }
        }
    </script>
</head>
<body>
    <h2>Panel de Administrador</h2>
    <a href="creacionUsuario.php" class="btn-usuarios">Creación de Usuario</a>
