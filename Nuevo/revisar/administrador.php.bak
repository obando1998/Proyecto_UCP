<?php
session_start();

// Verificar si el usuario es administrador
if (!isset($_SESSION['rol']) || $_SESSION['rol'] != 'admin') {
    header("Location: login.php");
    exit();
}

include 'connection.php';
$conn = connection();

// Obtener todas las solicitudes
$sql_solicitudes = "SELECT * FROM solicitudes";
$result_solicitudes = $conn->query($sql_solicitudes);

// Obtener todos los técnicos
$sql_tecnicos = "SELECT * FROM usuarios WHERE rol = 'tecnico'";
$result_tecnicos = $conn->query($sql_tecnicos);

// Procesar la asignación de solicitudes
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $solicitud_id = $_POST['solicitud_id'];
    $tecnico_id = $_POST['tecnico_id'];

    // Actualizar la solicitud con el técnico asignado
    $sql = "UPDATE solicitudes SET estado = 'asignada', asignado_a = '$tecnico_id' WHERE id = '$solicitud_id'";
    if ($conn->query($sql) === TRUE) {
        echo "Solicitud asignada con éxito.";
    } else {
        echo "Error: " . $sql . "<br>" . $conn->error;
    }
}

$conn->close();
?>

